# Required for live data
FOOTBALL_DATA_API_TOKEN=

# API-Football (API-Sports) - optional but recommended for wider coverage
API_FOOTBALL_KEY=
API_FOOTBALL_RAPIDAPI_KEY=

# Optional: used for team badges if you wire it in later
THESPORTSDB_API_KEY=123

# Cache TTL in seconds
CACHE_TTL_SECONDS=900

# Limit detailed per-fixture calls to avoid free plan rate limits
DETAILS_MAX_FIXTURES=12
